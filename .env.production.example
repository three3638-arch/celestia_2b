# ===== 数据库 =====
DATABASE_URL=postgresql://celestia:YOUR_STRONG_PASSWORD@db:5432/celestia
DB_PASSWORD=YOUR_STRONG_PASSWORD

# ===== 认证 =====
JWT_SECRET=YOUR_JWT_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=7d
COOKIE_DOMAIN=.your-domain.com

# ===== 应用 =====
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://your-domain.com
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_CURRENCY=SAR

# ===== Cloudflare R2 存储 =====
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=celestia
R2_PUBLIC_URL=https://your-r2-domain.com

# ===== 阿里云机器翻译 =====
ALIMT_ACCESS_KEY_ID=your_alimt_key
ALIMT_ACCESS_KEY_SECRET=your_alimt_secret
ALIMT_REGION=cn-hangzhou
