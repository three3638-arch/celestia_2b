# ===== 数据库 =====
DATABASE_URL=postgresql://celestia:YOUR_STRONG_PASSWORD@db:5432/celestia
DB_PASSWORD=YOUR_STRONG_PASSWORD

# ===== 认证 =====
JWT_SECRET=YOUR_JWT_SECRET_AT_LEAST_32_CHARS
SHOP_JWT_SECRET=YOUR_SHOP_JWT_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=7d
COOKIE_DOMAIN=.your-domain.com

# ===== 2C 管理员种子（生产首次部署必填）=====
SHOP_ADMIN_PHONE=13900000001
SHOP_ADMIN_PASSWORD=YOUR_STRONG_SHOP_ADMIN_PASSWORD

# ===== 应用 =====
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://celestia.com
NEXT_PUBLIC_MARKETING_URL=https://celestia.com
NEXT_PUBLIC_SHOP_URL=https://shop.celestia.com
NEXT_PUBLIC_B2B_URL=https://products.celestia.com
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_CURRENCY=SAR

# ===== 官网联系信息（可选，构建时注入）=====
NEXT_PUBLIC_CONTACT_EMAIL=contact@celestia.com
NEXT_PUBLIC_CONTACT_PHONE=+966XXXXXXXXX

# ===== 限流（推荐生产配置 Upstash Redis）=====
# Upstash: 控制台复制 Redis URL（rediss://...）
REDIS_URL=
# 强制内存限流（本地开发）: RATE_LIMIT_STORE=memory

# ===== Cloudflare Turnstile（公开表单 CAPTCHA，可选）=====
# 未配置时跳过验证；配置后须同时设置 site + secret，且 site key 参与 Docker build
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ===== Cloudflare R2 存储 =====
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=celestia
R2_PUBLIC_URL=https://your-r2-domain.com

# ===== 阿里云机器翻译 =====
ALIMT_ACCESS_KEY_ID=your_alimt_key
ALIMT_ACCESS_KEY_SECRET=your_alimt_secret
ALIMT_REGION=cn-hangzhou
