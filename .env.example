# Database
DATABASE_URL="postgresql://celestia:celestia_dev@localhost:5432/celestia"
DB_PASSWORD=celestia_dev

# Authentication
JWT_SECRET=your-jwt-secret-change-in-production
SHOP_JWT_SECRET=your-shop-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# 2C 管理员种子（仅 seed-shop-admin.ts 使用；生产必填）
SHOP_ADMIN_PHONE=
SHOP_ADMIN_PASSWORD=

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=celestia
R2_PUBLIC_URL=

# Alibaba Cloud Translation
ALIMT_ACCESS_KEY_ID=
ALIMT_ACCESS_KEY_SECRET=

# App
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_CURRENCY=SAR
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_SHOP_URL=http://localhost:3000
NEXT_PUBLIC_B2B_URL=http://localhost:3000
COOKIE_DOMAIN=

# Rate limiting (optional; set REDIS_URL in production)
REDIS_URL=
RATE_LIMIT_STORE=memory

# Cloudflare Turnstile (optional)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 1688 Open Platform
ALI_1688_APP_KEY=
ALI_1688_APP_SECRET=
